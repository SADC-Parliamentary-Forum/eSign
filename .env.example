# SADC-eSign Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME="SADC-eSign"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# =============================================================================
# Database Configuration
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sadc_esign
DB_USERNAME=sadc_esign
DB_PASSWORD=secret

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# =============================================================================
# MinIO Object Storage
# =============================================================================
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# =============================================================================
# Mail Configuration (Mailpit for dev)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@sadcpf.org"
MAIL_FROM_NAME="SADC-eSign"

# =============================================================================
# Security Keys (CHANGE IN PRODUCTION!)
# =============================================================================
APP_KEY=
JWT_SECRET=
ENCRYPTION_KEY=

# =============================================================================
# MFA Configuration
# =============================================================================
MFA_ISSUER="SADC-eSign"
MFA_ENABLED=true

# =============================================================================
# Queue Configuration
# =============================================================================
QUEUE_CONNECTION=redis
