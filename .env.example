# SADC-eSign Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME="SADC-eSign"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000

# =============================================================================
# Database Configuration
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sadc_esign
DB_USERNAME=sadc_esign
DB_PASSWORD=secret

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# =============================================================================
# MinIO Object Storage
# =============================================================================
MINIO_USE_PATH_STYLE_ENDPOINT=true
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_USE_SSL=false
SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN=http://minio:9000

# =============================================================================
# Mail Configuration (Mailpit for dev)
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@sadcpf.org"
MAIL_FROM_NAME="SADC-eSign"

# =============================================================================
# Security Keys (CHANGE IN PRODUCTION!)
# =============================================================================
APP_KEY=
JWT_SECRET=
ENCRYPTION_KEY=

# =============================================================================
# MFA Configuration
# =============================================================================
MFA_ISSUER="SADC-eSign"
MFA_ENABLED=true

# =============================================================================
# Queue Configuration
# =============================================================================
QUEUE_CONNECTION=redis

# =============================================================================
# Local Dev Admin Seeder Credentials (backend local/development only)
# =============================================================================
DEV_ADMIN_NAME="Dev Admin"
DEV_ADMIN_EMAIL=admin@esign.local
DEV_ADMIN_PASSWORD=Admin@12345
