APP_ENV=production
APP_DEBUG=false
APP_URL=https://esign.sadcpf.org

# Database
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=sadc_esign
DB_USERNAME=sadc_esign
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION
REDIS_PORT=6379

# Reverb (WebSockets)
REVERB_APP_ID=54321
REVERB_APP_KEY=CHANGE_ME_IN_PRODUCTION
REVERB_APP_SECRET=CHANGE_ME_IN_PRODUCTION
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ReCAPTCHA
RECAPTCHA_SITE_KEY=CHANGE_ME_IN_PRODUCTION
RECAPTCHA_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Logging (use 'production' for JSON output to stdout for container log aggregation)
LOG_CHANNEL=production
LOG_LEVEL=info
