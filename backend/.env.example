APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Set to false in production (forced off when APP_ENV=production)
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000
# Production: set to exact frontend origin(s), e.g. https://esign.sadcpf.org (comma-separated if multiple)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
PROCESSING_DISK_ROOT=/tmp/esign-processing
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail defaults for local capture via Mailpit (non-production)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Outlook/Microsoft 365 SMTP (real mailbox delivery)
# MAIL_MAILER=smtp
# MAIL_SCHEME=null
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USERNAME=your-account@your-domain.com
# MAIL_PASSWORD=your-password-or-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="your-account@your-domain.com"
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
REVERB_APP_ID=esign
REVERB_APP_KEY=4c75bbe4bc2986cca241be38054f10a106a2f5f9
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
# Local dev seed credentials (used by DatabaseSeeder in local/development only)
DEV_ADMIN_NAME="Dev Admin"
DEV_ADMIN_EMAIL=admin@esign.local
DEV_ADMIN_PASSWORD=Admin@12345
