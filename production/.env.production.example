# eSign Production Environment Configuration
# IMPORTANT: Never commit actual secrets to the repository.

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME="SADC-eSign"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://esign.sadcpf.org

# =============================================================================
# Database Configuration
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=sadc_esign
DB_USERNAME=sadc_esign
DB_PASSWORD=YOUR_SECURE_PASSWORD

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# =============================================================================
# MinIO / S3 Object Storage
# =============================================================================
MINIO_ENDPOINT=https://storage.sadcpf.org
MINIO_ACCESS_KEY=YOUR_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_SECRET_KEY
MINIO_BUCKET=documents
MINIO_USE_SSL=true

# =============================================================================
# Mail Configuration
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_MAIL_USER
MAIL_PASSWORD=YOUR_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="esign@sadcpf.org"
MAIL_FROM_NAME="SADC-eSign"

# =============================================================================
# Security Keys (KEEP THESE SECRET!)
# =============================================================================
APP_KEY=
JWT_SECRET=
ENCRYPTION_KEY=

# =============================================================================
# MFA Configuration
# =============================================================================
MFA_ISSUER="SADC-eSign"
MFA_ENABLED=true

# =============================================================================
# Queue Configuration
# =============================================================================
QUEUE_CONNECTION=redis

# =============================================================================
# WebSocket (Reverb) Configuration
# =============================================================================
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=esign.sadcpf.org
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=https
